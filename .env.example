# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ── LLM rationale provider (pluggable) ───────────────────────────────────
# LLM_PROVIDER: anthropic (default) | openai
#   openai = ANY OpenAI-compatible endpoint (Ollama, Qwen/DashScope, OpenRouter,
#   Groq, GLM, vLLM, …). Swap models for experiments by editing these vars only.
# LLM_MODEL: override the model id (defaults: anthropic→claude-opus-4-8, openai→qwen2.5)
LLM_PROVIDER=anthropic
LLM_MODEL=

# Anthropic (LLM_PROVIDER=anthropic) — server-side only; never reaches frontend JS
ANTHROPIC_API_KEY=

# OpenAI-compatible (LLM_PROVIDER=openai). Examples:
#   Ollama (local, free): OPENAI_BASE_URL=http://localhost:11434/v1  OPENAI_API_KEY=ollama  LLM_MODEL=qwen2.5
#   Qwen / DashScope:     OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
#   OpenRouter:           OPENAI_BASE_URL=https://openrouter.ai/api/v1  LLM_MODEL=qwen/qwen-2.5-72b-instruct
OPENAI_BASE_URL=
OPENAI_API_KEY=

# ── Neo4j ────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
